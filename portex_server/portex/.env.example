# Copy this file to .env and fill in real values. .env is gitignored.
# Generate a fresh SECRET_KEY with:
#   python -c "from secrets import token_urlsafe; print(token_urlsafe(50))"
SECRET_KEY=replace-me-with-a-long-random-string
DEBUG=False

# DB CONF
DB_ENGINE=postgresql_psycopg2
POSTGRES_DB=portex
POSTGRES_USER=portex_user
POSTGRES_PASSWORD=replace-me-with-a-strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

CORS_ALLOWED_ORIGINS=https://portex.live,https://www.portex.live
MAIN_HOST=portex.live
